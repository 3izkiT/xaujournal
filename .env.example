# XAURite environment variables — copy to `.env.local` for local dev

# Core
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-openssl-rand-base64-32
DATABASE_URL=postgresql://user:pass@localhost:5432/xaurite

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Turnstile (optional locally; required in production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Growth / monetization defaults
NEXT_PUBLIC_OPEN_ACCESS_MODE=true
NEXT_PUBLIC_PAYMENTS_ENABLED=false
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Auth modes
# NEXT_PUBLIC_EMAIL_AUTH_ENABLED=true
# NEXT_PUBLIC_DEMO_AUTH_ENABLED=true

# Email auth (only if NEXT_PUBLIC_EMAIL_AUTH_ENABLED=true)
# RESEND_API_KEY=
# EMAIL_FROM=onboarding@resend.dev

# Stripe (when NEXT_PUBLIC_PAYMENTS_ENABLED=true)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PREMIUM_PRICE_ID=price_...

# Analytics / SEO (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Competitor audit scripts (optional)
# XAU_AUDIT_FIREBASE_API_KEY=
# XAU_AUDIT_EMAIL=
# XAU_AUDIT_PASS=
