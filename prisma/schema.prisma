generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum Plan {

  FREE

  PREMIUM_GOLD

}



enum TradeType {

  BUY

  SELL

}



enum SessionType {

  SYDNEY

  TOKYO

  LONDON

  NEW_YORK

}



enum EmotionType {

  CALM

  GREED

  FEAR

  FOMO

  REVENGE_TRADING

  OVERLOT

}



enum RiskModel {

  FIXED_LOT

  FIXED_PERCENT

  VOLATILITY

}



enum TemplatePreset {

  SCALP

  INTRADAY

  SWING

}



enum AuthTokenType {

  EMAIL_VERIFY

  PASSWORD_RESET

}



model User {

  id              String        @id @default(cuid())

  email           String        @unique

  name            String

  passwordHash    String?

  googleId        String?       @unique

  emailVerifiedAt DateTime?

  plan            Plan          @default(FREE)

  createdAt       DateTime      @default(now())

  updatedAt       DateTime      @updatedAt

  trades          Trade[]

  settings        UserSettings?

  shareLinks      ShareLink[]

  authTokens      AuthToken[]

}



model AuthToken {

  id        String        @id @default(cuid())

  userId    String

  type      AuthTokenType

  tokenHash String        @unique

  expiresAt DateTime

  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, type])

}



model UserSettings {

  id               String         @id @default(cuid())

  userId           String         @unique

  customChecklist  Json?

  customSetupTags  String[]       @default([])

  customErrorTags  String[]       @default([])

  riskModel        RiskModel      @default(FIXED_PERCENT)

  templatePreset   TemplatePreset @default(INTRADAY)

  createdAt        DateTime       @default(now())

  updatedAt        DateTime       @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model ShareLink {

  id        String    @id @default(cuid())

  userId    String

  token     String    @unique

  label     String    @default("Coach view")

  expiresAt DateTime?

  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId])

}



model Trade {

  id                 String      @id @default(cuid())

  userId             String

  asset              String      @default("XAUUSD (Gold)")

  date               DateTime

  entryAt            DateTime    @default(now())

  exitAt             DateTime?

  holdTimeMinutes    Int?

  type               TradeType

  netProfitLoss      Decimal     @db.Decimal(12, 2)

  rMultiple          String

  entryPrice         Decimal     @db.Decimal(10, 2)

  exitPrice          Decimal     @db.Decimal(10, 2)

  mae                Decimal?    @db.Decimal(12, 2)

  mfe                Decimal?    @db.Decimal(12, 2)

  session            SessionType

  setupTags          String[]

  emotion            EmotionType

  beforeChartUrl     String

  afterChartUrl      String

  followedPlan       Boolean

  rrAtLeastOneToTwo  Boolean

  calmMindset        Boolean

  disciplineScore    Int

  noteContext        String      @default("")

  noteMistake        String      @default("")

  noteNextAction     String      @default("")

  createdAt          DateTime    @default(now())

  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, date(sort: Desc)])

  @@index([userId, session])

  @@index([userId, disciplineScore])

  @@index([userId, entryAt])

}


